# Copy to .env. Only needed to deploy the contract to a PUBLIC network
# (Sepolia) — local development with `npm run dev` needs none of this.

# An RPC endpoint for the Sepolia testnet (e.g. from Alchemy or Infura).
# Example: https://eth-sepolia.g.alchemy.com/v2/<your-key>
SEPOLIA_RPC_URL=

# Private key of the wallet that DEPLOYS and OWNS the contract (the issuer).
# Use a FRESH throwaway account funded with Sepolia test ETH — NEVER a real
# key that holds real funds. This is the account you'll import into MetaMask
# to issue/revoke transcripts.
PRIVATE_KEY=
