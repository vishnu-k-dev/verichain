# =====================================================================
# Blockchain-Based Academic Transcript Verification System — env sample
# Copy to `.env` and fill in. NEVER commit the real .env.
# =====================================================================

# ---------- Blockchain ----------
# Operator/owner wallet. On local Ganache use the first deterministic account.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# HD mnemonic used to derive per-institution custodial wallets.
# Default matches the standard local dev mnemonic (accounts are pre-funded).
BLOCKCHAIN_MNEMONIC=test test test test test test test test test test test junk
GANACHE_URL=http://127.0.0.1:7545
SEPOLIA_RPC_URL=
# Filled in automatically by the deploy script (backend/src/config/contract.json),
# but you can override the address here.
CONTRACT_ADDRESS=
# Which RPC the backend talks to: "ganache" | "sepolia"
BLOCKCHAIN_NETWORK=ganache
ETHERSCAN_API_KEY=

# ---------- Backend ----------
MONGO_URI=mongodb://127.0.0.1:27017/transcript_verification
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Pinata / IPFS. If left blank the backend falls back to a local mock store
# so the full flow still works without external credentials.
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
PINATA_JWT=

# ---------- Frontend ----------
VITE_API_URL=http://localhost:5000/api
VITE_CONTRACT_ADDRESS=
