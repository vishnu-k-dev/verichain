# All optional — the defaults below work for a local Hardhat chain.
# Copy to .env only if you want to change something.

PORT=5000
RPC_URL=http://127.0.0.1:8545

# The wallet that issues transcripts (the contract owner).
# This is Hardhat's well-known account #0 — LOCAL DEV ONLY, never use on a real network.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

FRONTEND_URL=http://localhost:5173

# Only needed to deploy to the public Sepolia testnet:
SEPOLIA_RPC_URL=
